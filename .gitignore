# ---------------------------------------------------------------------------
# Agent Hub — .gitignore (C# / .NET Framework + Vanilla JS frontend)
# ---------------------------------------------------------------------------

# ===== Visual Studio / Rider =====
.vs/
.idea/
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ===== Build results =====
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
[Dd]ebugPublic/
[Rr]eleases/
x64/
x86/
[Ww][Ii][Nn]32/
[Aa][Rr][Mm]/
[Aa][Rr][Mm]64/
build/
bld/
[Ll]og/
[Ll]ogs/

# Build output of this solution (csproj OutputPath -> install\Debug|Release).
# The Inno Setup source script (install/Installer.iss) is kept.
install/Debug/
install/Release/

# ===== NuGet =====
# packages.config-style restore folder (this repo uses packages.config).
packages/
*.nupkg
*.snupkg
.nuget/
project.lock.json
project.assets.json
*.nuget.props
*.nuget.targets

# ===== MSBuild / VS temp =====
*.tlog
*.log
*.binlog
*.ilk
*.meta
*.obj
*.iobj
*.pch
*.pdb
*.ipdb
*.pgc
*.pgd
*.rsp
*.sbr
*.tmp
*.tmp_proj
*_wpftmp.csproj
*.cache
*.VC.db
*.VC.VC.opendb

# ===== Test / coverage =====
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
*.coverage
*.coveragexml
TestResults/

# ===== Secrets / certificates (never commit) =====
# Self-signed cert is generated at runtime into the output folder.
*.pfx
*.crt
*.p12
*.key
appsettings.*.local.json
secrets.json

# ===== Runtime logs =====
logs.Api/
*.log.txt
log-*.txt

# ===== Vanilla JS frontend tooling (optional; no bundler required) =====
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
package-lock.json.bak
.parcel-cache/
dist/

# ===== OS files =====
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
.DS_Store
.AppleDouble
.LSOverride
